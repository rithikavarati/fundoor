import Debug "mo:core/Debug";
import Map "mo:core/Map";
import Types "../types/common";
import Char "mo:core/Char";
import Nat32 "mo:core/Nat32";

module {
  public type Activity = Types.Activity;

  /// Returns activities in the 'Weekend Activities' category for a given city and state,
  /// optionally filtered to upcoming events within the next 1-2 weeks from the provided date.
  /// currentDate is an ISO 8601 date string (YYYY-MM-DD); pass null to skip date filtering.
  public func weekendEventsByCityAndState(
    store : Map.Map<Nat, Activity>,
    city : Text,
    state : Text,
    currentDate : ?Text,
  ) : [Activity] {
    let targetLocation = (city.trim(#char ' ') # ", " # state.trim(#char ' ')).toLower();
    var result : [Activity] = [];
    for ((_, activity) in store.entries()) {
      if (activity.category == "Weekend Activities" and activity.location.toLower() == targetLocation) {
        let shouldInclude = switch (currentDate, activity.eventDate) {
          case (?today, ?evDate) {
            // Only include events whose eventDate falls within next 14 days of today.
            // We compare ISO 8601 date strings lexicographically (YYYY-MM-DD sorts correctly).
            let endWindow = dateAddDays(today, 14);
            evDate >= today and evDate <= endWindow
          };
          // If no currentDate filter requested, include all with an eventDate.
          case (null, ?_) { true };
          // If activity has no eventDate, exclude it (these are permanent/standing activities).
          case (_, null) { false };
        };
        if (shouldInclude) {
          result := result.concat([activity]);
        };
      };
    };
    result;
  };

  // Adds days to a YYYY-MM-DD date string and returns a new YYYY-MM-DD string.
  // This is a simple implementation that handles day/month overflow for filtering.
  private func dateAddDays(date : Text, days : Nat) : Text {
    // Parse YYYY-MM-DD
    let parts = date.split(#char '-');
    var year = 0;
    var month = 0;
    var day = 0;
    var i = 0;
    for (p in parts) {
      if (i == 0) { year := textToNat(p) }
      else if (i == 1) { month := textToNat(p) }
      else if (i == 2) { day := textToNat(p) };
      i += 1;
    };
    // Add days by counting month lengths (handles overflow)
    day := day + days;
    let daysInMonth = [31, 28, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31];
    label overflow loop {
      let isLeap = (year % 4 == 0 and year % 100 != 0) or year % 400 == 0;
      let dim : Nat = if (month == 2 and isLeap) 29 else daysInMonth[month - 1];
      if (day > dim) {
        day -= dim;
        month += 1;
        if (month > 12) { month := 1; year += 1 };
      } else {
        break overflow;
      };
    };
    natToPadded(year, 4) # "-" # natToPadded(month, 2) # "-" # natToPadded(day, 2);
  };

  private func textToNat(t : Text) : Nat {
    var n = 0;
    for (c in t.chars()) {
      let d = c.toNat32() - 48;
      n := n * 10 + d.toNat();
    };
    n;
  };

  private func natToPadded(n : Nat, width : Nat) : Text {
    var s = debug_show(n);
    // Remove surrounding quotes added by debug_show for Nat
    // Actually in Motoko debug_show on Nat produces plain digits, but we use Nat.toText
    s := natToText(n);
    while (s.size() < width) {
      s := "0" # s;
    };
    s;
  };

  private func natToText(n : Nat) : Text {
    if (n == 0) return "0";
    var digits : [Nat] = [];
    var x = n;
    while (x > 0) {
      digits := [x % 10].concat(digits);
      x := x / 10;
    };
    var s = "";
    for (d in digits.vals()) {
      s := s # charOfDigit(d);
    };
    s;
  };

  private func charOfDigit(d : Nat) : Text {
    switch (d) {
      case 0 "0"; case 1 "1"; case 2 "2"; case 3 "3"; case 4 "4";
      case 5 "5"; case 6 "6"; case 7 "7"; case 8 "8"; case 9 "9";
      case _ "?";
    };
  };

  /// Returns all activities sorted by id.
  public func listAll(store : Map.Map<Nat, Activity>) : [Activity] {
    var result : [Activity] = [];
    for ((_, activity) in store.entries()) {
      result := result.concat([activity]);
    };
    result;
  };

  /// Returns all activities matching the given category (exact, case-sensitive).
  public func byCategory(store : Map.Map<Nat, Activity>, category : Text) : [Activity] {
    var result : [Activity] = [];
    for ((_, activity) in store.entries()) {
      if (activity.category == category) {
        result := result.concat([activity]);
      };
    };
    result;
  };

  /// Returns activities matching a city and state (case-insensitive exact location match).
  /// Matches the format "City, State" stored in activity.location.
  public func byCityAndState(store : Map.Map<Nat, Activity>, city : Text, state : Text) : [Activity] {
    let targetLocation = (city.trim(#char ' ') # ", " # state.trim(#char ' ')).toLower();
    var result : [Activity] = [];
    for ((_, activity) in store.entries()) {
      if (activity.location.toLower() == targetLocation) {
        result := result.concat([activity]);
      };
    };
    result;
  };

  /// Returns activities matching a city and state filtered by category.
  public func byCityStateAndCategory(store : Map.Map<Nat, Activity>, city : Text, state : Text, category : Text) : [Activity] {
    let targetLocation = (city.trim(#char ' ') # ", " # state.trim(#char ' ')).toLower();
    var result : [Activity] = [];
    for ((_, activity) in store.entries()) {
      if (activity.location.toLower() == targetLocation and activity.category == category) {
        result := result.concat([activity]);
      };
    };
    result;
  };

  /// Case-insensitive search across name, location, category, and tags.
  public func search(store : Map.Map<Nat, Activity>, searchTerm : Text) : [Activity] {
    let lower = searchTerm.toLower();
    var result : [Activity] = [];
    for ((_, activity) in store.entries()) {
      let matches =
        activity.name.toLower().contains(#text lower) or
        activity.location.toLower().contains(#text lower) or
        activity.category.toLower().contains(#text lower);
      if (matches) {
        result := result.concat([activity]);
      };
    };
    result;
  };

  /// Looks up a single activity by id; traps if not found.
  public func byId(store : Map.Map<Nat, Activity>, id : Nat) : ?Activity {
    store.get(id);
  };

